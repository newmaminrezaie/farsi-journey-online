// HiGooya Prisma schema — flat model matching the frontend.
// All prices are integer Toman. Dates stored as ISO (Postgres timestamptz / date).

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// -------------------- Staff / auth --------------------

enum StaffRole {
  admin
  staff
}

enum NotifyEvent {
  registration_new
  book_order_new
  book_order_paid
}

model StaffUser {
  id              String        @id @default(cuid())
  username        String        @unique
  passwordHash    String
  fullName        String
  role            StaffRole     @default(staff)
  baleChatId      String?
  telegramChatId  String?
  notifyOn        NotifyEvent[] @default([])
  active          Boolean       @default(true)
  createdAt       DateTime      @default(now())
  auditEntries    AuditLog[]
}

// -------------------- Catalog --------------------

model Teacher {
  id           String   @id @default(cuid())
  nameFa       String
  nameEn       String   @default("")
  bioFa        String   @default("")
  photoUrl     String   @default("")
  specialties  String[] @default([])
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
}

model Employee {
  id           String   @id @default(cuid())
  nameFa       String
  nameEn       String   @default("")
  roleFa       String   @default("")     // نقش، مثلاً منشی، مسئول ثبت‌نام
  bioFa        String   @default("")
  photoUrl     String   @default("")
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
}

model Semester {
  id          String   @id @default(cuid())
  classCode   String   @unique @default("")
  titleFa     String
  level       String   @default("beginner")
  teacherIds  String[] @default([])
  bookIds     String[] @default([])
  scheduleFa  String   @default("")
  startsOn    DateTime @db.Date
  endsOn      DateTime @db.Date
  capacity    Int      @default(0)
  seatsTaken  Int      @default(0)
  priceToman  Int      @default(0)
  mode        String   @default("in-person")   // in-person | online | hybrid
  status      String   @default("open")        // open | closed | archived
  createdAt   DateTime @default(now())
}

// -------------------- Registrations (public form) --------------------

model Registration {
  id                 String    @id @default(cuid())
  semesterId         String?
  fullName           String
  fatherName         String    @default("")
  birthCertNo        String    @default("")
  nationalId         String    @default("")
  issuedFrom         String    @default("")
  birthPlace         String    @default("")
  schoolDegree       String    @default("")
  universityDegree   String    @default("")
  address            String    @default("")
  phone              String
  landline           String    @default("")
  termInterest       String    @default("")
  levelInterest      String    @default("")
  selectedTeacherId  String    @default("")
  selectedBookId     String    @default("")
  note               String    @default("")
  agreedToTerms      Boolean   @default(false)
  paidToman          Int       @default(0)
  paidAt             DateTime?
  paymentRef         String    @default("")
  status             String    @default("new")   // new | contacted | enrolled | rejected
  createdAt          DateTime  @default(now())

  @@index([semesterId])
  @@index([phone])
}

// -------------------- Book shop --------------------

model Book {
  id             String   @id @default(cuid())
  titleFa        String
  titleEn        String   @default("")
  author         String   @default("")
  level          String   @default("")
  category       String   @default("")
  descriptionFa  String   @default("")
  coverUrl       String   @default("")
  priceToman     Int
  stock          Int      @default(0)
  active         Boolean  @default(true)
  createdAt      DateTime @default(now())
}

// -------------------- Notifications & audit --------------------

enum NotifyChannel {
  bale
  telegram
}

enum NotifyStatus {
  queued
  sent
  failed
}

model Notification {
  id               String        @id @default(cuid())
  event            NotifyEvent
  channel          NotifyChannel
  recipientChatId  String
  text             String
  status           NotifyStatus  @default(queued)
  attempts         Int           @default(0)
  lastError        String?
  nextAttemptAt    DateTime      @default(now())
  sentAt           DateTime?
  createdAt        DateTime      @default(now())

  @@index([status, nextAttemptAt])
}

model AuditLog {
  id         String    @id @default(cuid())
  actorId    String?
  action     String
  entity     String
  entityId   String
  diff       Json?
  createdAt  DateTime  @default(now())

  actor      StaffUser? @relation(fields: [actorId], references: [id])
}
