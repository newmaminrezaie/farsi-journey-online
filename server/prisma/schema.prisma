// HiGooya Prisma schema — matches the approved plan (section 3).
// All prices are integer Toman. Dates stored as ISO (Postgres timestamptz / date).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// -------------------- Staff / auth --------------------

enum StaffRole {
  admin
  staff
}

enum NotifyEvent {
  enrollment_paid
  registration_new
  book_order_paid
  book_order_new
}

model StaffUser {
  id              String        @id @default(cuid())
  username        String        @unique
  passwordHash    String
  fullName        String
  role            StaffRole     @default(staff)
  baleChatId      String?
  telegramChatId  String?
  notifyOn        NotifyEvent[] @default([])
  active          Boolean       @default(true)
  createdAt       DateTime      @default(now())
  auditEntries    AuditLog[]
}

// -------------------- Catalog --------------------

model Teacher {
  id           String         @id @default(cuid())
  nameFa       String
  nameEn       String
  bioFa        String         @default("")
  photoUrl     String         @default("")
  specialties  String[]       @default([])
  active       Boolean        @default(true)
  createdAt    DateTime       @default(now())
  sessions     ClassSession[]
}

model Course {
  id             String         @id @default(cuid())
  code           String         @unique
  titleFa        String
  level          String
  category       String
  descriptionFa  String         @default("")
  active         Boolean        @default(true)
  createdAt      DateTime       @default(now())
  sessions       ClassSession[]
}

enum SemesterSeason {
  spring
  summer
  fall
  winter
}

enum RegistrationStatus {
  draft
  open
  closed
  archived
}

model Semester {
  id                 String             @id @default(cuid())
  titleFa            String
  jalaliYear         Int
  season             SemesterSeason
  startsOn           DateTime           @db.Date
  endsOn             DateTime           @db.Date
  registrationStatus RegistrationStatus @default(draft)
  createdAt          DateTime           @default(now())
  sessions           ClassSession[]
  enrollments        Enrollment[]
}

enum ClassMode {
  in_person
  online
  hybrid
}

enum ClassStatus {
  open
  full
  closed
}

model ClassSession {
  id           String       @id @default(cuid())
  courseId     String
  teacherId    String
  semesterId   String
  scheduleFa   String
  mode         ClassMode    @default(in_person)
  capacity     Int
  seatsTaken   Int          @default(0)
  priceToman   Int
  status       ClassStatus  @default(open)
  notes        String       @default("")
  createdAt    DateTime     @default(now())

  course       Course       @relation(fields: [courseId], references: [id])
  teacher      Teacher      @relation(fields: [teacherId], references: [id])
  semester     Semester     @relation(fields: [semesterId], references: [id])
  enrollments  Enrollment[]

  @@unique([courseId, teacherId, semesterId])
  @@index([semesterId])
}

// -------------------- Students --------------------

model Student {
  id            String       @id @default(cuid())
  studentNumber String       @unique
  firstName     String
  lastName      String
  fatherName    String       @default("")
  phone         String
  nationalId    String?      @unique
  birthDate     DateTime?    @db.Date
  address       String       @default("")
  note          String       @default("")
  createdAt     DateTime     @default(now())
  enrollments   Enrollment[]

  @@index([phone])
}

enum EnrollmentStatus {
  pending
  active
  completed
  cancelled
  refunded
}

enum PaymentMethod {
  zarinpal
  cash
  card_to_card
  admin_manual
}

model Enrollment {
  id               String           @id @default(cuid())
  studentId        String
  classSessionId   String
  semesterId       String
  status           EnrollmentStatus @default(pending)
  priceToman       Int
  amountPaidToman  Int              @default(0)
  paymentMethod    PaymentMethod
  paymentRef       String?
  enrolledAt       DateTime         @default(now())

  student          Student          @relation(fields: [studentId], references: [id])
  classSession     ClassSession     @relation(fields: [classSessionId], references: [id])
  semester         Semester         @relation(fields: [semesterId], references: [id])

  @@unique([studentId, classSessionId])
  @@index([semesterId, status])
}

// -------------------- Book shop --------------------

model Book {
  id             String          @id @default(cuid())
  titleFa        String
  author         String          @default("")
  level          String          @default("")
  category       String          @default("")
  descriptionFa  String          @default("")
  coverUrl       String          @default("")
  priceToman     Int
  stock          Int             @default(0)
  active         Boolean         @default(true)
  createdAt      DateTime        @default(now())
  orderItems     BookOrderItem[]
}

enum BookOrderStatus {
  pending
  paid
  shipped
  completed
  cancelled
}

model BookOrder {
  id                 String           @id @default(cuid())
  refCode            String           @unique
  customerName       String
  phone              String
  address            String
  note               String           @default("")
  subtotalToman      Int
  status             BookOrderStatus  @default(pending)
  paymentMethod      PaymentMethod
  zarinpalAuthority  String?
  zarinpalRefId      String?
  createdAt          DateTime         @default(now())
  items              BookOrderItem[]
}

model BookOrderItem {
  id              String    @id @default(cuid())
  orderId         String
  bookId          String
  titleFa         String
  qty             Int
  unitPriceToman  Int

  order           BookOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  book            Book      @relation(fields: [bookId], references: [id])
}

// -------------------- Payments & notifications & audit --------------------

model Payment {
  id           String   @id @default(cuid())
  kind         String   // 'enrollment' | 'book_order'
  targetId     String
  amountToman  Int
  provider     String   // 'zarinpal' | 'manual'
  authority    String?
  refId        String?
  status       String   // 'pending' | 'ok' | 'failed'
  rawResponse  Json?
  createdAt    DateTime @default(now())
}

enum NotifyChannel {
  bale
  telegram
}

enum NotifyStatus {
  queued
  sent
  failed
}

model Notification {
  id               String        @id @default(cuid())
  event            NotifyEvent
  channel          NotifyChannel
  recipientChatId  String
  text             String
  status           NotifyStatus  @default(queued)
  attempts         Int           @default(0)
  lastError        String?
  nextAttemptAt    DateTime      @default(now())
  sentAt           DateTime?
  createdAt        DateTime      @default(now())

  @@index([status, nextAttemptAt])
}

model AuditLog {
  id         String    @id @default(cuid())
  actorId    String?
  action     String
  entity     String
  entityId   String
  diff       Json?
  createdAt  DateTime  @default(now())

  actor      StaffUser? @relation(fields: [actorId], references: [id])
}
