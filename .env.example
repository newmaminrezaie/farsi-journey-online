# Copy to `.env` on the VPS and fill in real values. Never commit .env.

# --- Database ---
POSTGRES_USER=higooya
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=higooya

# --- Auth ---
# Generate with: openssl rand -hex 48
JWT_SECRET=change-me-64-hex-chars-min
COOKIE_DOMAIN=higooya.ir

# --- Public URL (for Zarinpal callback and Bale/Telegram links) ---
PUBLIC_BASE_URL=https://higooya.ir

# --- Notifications ---
# Bale (primary — works from Iran natively). Create via @botfather_bot on Bale.
BALE_BOT_TOKEN=
# Comma-separated fallback chat IDs. Used when no staff member is subscribed.
BALE_ADMIN_CHAT_IDS=

# Telegram (optional — leave BOT_TOKEN blank to disable).
# api.telegram.org is blocked from Iran, so requests go through this proxy.
# Supported schemes: http://, https://, socks5://
# Example: socks5://user:pass@proxy.example.com:1080
TELEGRAM_BOT_TOKEN=
TELEGRAM_PROXY_URL=
TELEGRAM_ADMIN_CHAT_IDS=

# --- Zarinpal ---
ZARINPAL_MERCHANT_ID=5b64f220-37e9-4a80-ab3d-9521bb8fcfe8
ZARINPAL_SANDBOX=false

# --- Off-site backup (optional) ---
# Configure `rclone config` first; then set the remote name here, e.g. arvan:higooya-backups
RCLONE_REMOTE=

# --- First admin bootstrap (used by `npm run seed:admin` once) ---
BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_PASSWORD=change-me-on-first-login
BOOTSTRAP_ADMIN_NAME=مدیر گویا
